DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
PRODUCT_CORE_PUBLIC_URL=http://localhost:3000
# Project Settings -> API -> service_role key. Used only server-side to roll back
# an auth user if member-row creation fails during signup. Optional but recommended.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_BOOTSTRAP_OWNER_PHONE=+12025550123
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
STAFF_AUTH_ENCRYPTION_KEY=
# Generate an independent random value with at least 32 characters.
STAFF_AUTH_PHONE_PEPPER=

# Sentry (uncomment and set DSN when Sentry project is created)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

