{
  "name": "@kclub/database",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:validate": "prisma validate --config prisma.config.ts",
    "lint": "eslint src prisma.config.ts --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "dotenv": "^16.0.0",
    "prisma": "^7.6.0",
    "tsx": "^4.23.1"
  }
}
