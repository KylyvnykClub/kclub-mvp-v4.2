generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum StaffRole {
  OWNER
  ADMIN
  MODERATOR
  SUPPORT
  FINANCE
  CONTENT_MANAGER
}

model StaffUser {
  id           String       @id @default(uuid()) @db.Uuid
  phoneHash    String       @unique @map("phone_hash")
  phoneCipher  String       @map("phone_cipher")
  role         StaffRole
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  credential   StaffCredential?
  invites      StaffInvite[]
  mfaMethods   StaffMfaMethod[]
  recoveryCodes StaffRecoveryCode[]
  sessions     StaffSession[]
  challenges   StaffAuthChallenge[]
  auditEvents  AuditEvent[] @relation("AuditActor")

  @@map("staff_users")
}

model StaffAuthChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  staffId    String    @map("staff_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  purpose    String
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  staff      StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, expiresAt])
  @@map("staff_auth_challenges")
}

model StaffAuthRateLimit {
  keyHash   String   @id @map("key_hash")
  count     Int
  resetAt   DateTime @map("reset_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([resetAt])
  @@map("staff_auth_rate_limits")
}

model StaffCredential {
  staffId      String   @id @map("staff_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  staff        StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_credentials")
}

model StaffInvite {
  id          String    @id @default(uuid()) @db.Uuid
  staffId     String    @map("staff_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  staff       StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, expiresAt])
  @@map("staff_invites")
}

model StaffMfaMethod {
  id           String    @id @default(uuid()) @db.Uuid
  staffId      String    @map("staff_id") @db.Uuid
  secretCipher String    @map("secret_cipher")
  verifiedAt   DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  staff        StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("staff_mfa_methods")
}

model StaffRecoveryCode {
  id         String    @id @default(uuid()) @db.Uuid
  staffId    String    @map("staff_id") @db.Uuid
  codeHash   String    @unique @map("code_hash")
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  staff      StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("staff_recovery_codes")
}

model StaffSession {
  id           String    @id @default(uuid()) @db.Uuid
  staffId      String    @map("staff_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt   DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  staff        StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, expiresAt])
  @@map("staff_sessions")
}

model AuditEvent {
  id           String    @id @default(uuid()) @db.Uuid
  actorStaffId String?   @map("actor_staff_id") @db.Uuid
  action       String
  resourceType String    @map("resource_type")
  resourceId   String?   @map("resource_id")
  requestId    String    @map("request_id") @db.Uuid
  metadata     Json
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  actor        StaffUser? @relation("AuditActor", fields: [actorStaffId], references: [id], onDelete: SetNull)

  @@index([actorStaffId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_events")
}

enum PartnerCategory {
  ADVISORY
  FINANCE
  LEGAL
  TECHNOLOGY
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Partner {
  id                   String              @id @default(uuid()) @db.Uuid
  slug                 String              @unique
  category             PartnerCategory
  country              String
  city                 String?
  phone                String?
  discountPercent      Int                 @map("discount_percent")
  image                String
  translations         Json
  isActive             Boolean             @default(true) @map("is_active")
  sortOrder            Int                 @default(0) @map("sort_order")

  ownerId              String?             @map("owner_id") @db.Uuid
  owner                Member?             @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  featuredTop          Boolean             @default(false) @map("featured_top")
  featuredRecommended  Boolean             @default(false) @map("featured_recommended")

  stripeCustomerId     String?             @map("stripe_customer_id")
  stripeSubscriptionId String?             @unique @map("stripe_subscription_id")
  stripePriceId        String?             @map("stripe_price_id")
  subscriptionStatus   SubscriptionStatus  @default(NONE) @map("subscription_status")
  currentPeriodStart   DateTime?           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime?           @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean             @default(false) @map("cancel_at_period_end")

  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("partners")
}

model Member {
  id              String   @id @default(uuid()) @db.Uuid
  supabaseUserId  String   @unique @map("supabase_user_id")
  phone           String   @unique
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  preferredLocale String   @default("en") @map("preferred_locale")
  
  displayName     String?  @map("display_name")
  company         String?
  position        String?
  bio             String?
  city            String?
  country         String?
  
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  partners              Partner[]
  membershipApplication MembershipApplication?

  @@map("members")
}

model MembershipApplication {
  id             String   @id @default(uuid()) @db.Uuid
  memberId       String   @unique @map("member_id") @db.Uuid
  motivation     String?
  referralSource String?  @map("referral_source")
  status         String   @default("SUBMITTED")
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("membership_applications")
}

model StripeWebhookEvent {
  id            String    @id @default(uuid()) @db.Uuid
  stripeEventId String    @unique @map("stripe_event_id")
  type          String
  payload       Json
  processedAt   DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("stripe_webhook_events")
}
